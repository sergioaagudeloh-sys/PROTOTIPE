rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Función helper: verifica que un token es válido y pertenece al clientId dado ───
    function tokenValido(token, clientId) {
      return exists(/databases/$(database)/documents/tokens/$(token))
        && get(/databases/$(database)/documents/tokens/$(token)).data.clientId == clientId
        && get(/databases/$(database)/documents/tokens/$(token)).data.active == true;
    }

    // ─── Reportes de facturación comisional ───────────────────────────────────────────
    match /reportesBilling/{reportId} {
      // La app cliente escribe su reporte si su token es válido
      allow create, update: if tokenValido(
        request.resource.data.token,
        request.resource.data.clientId
      );
      // Solo el desarrollador autenticado puede leer y eliminar
      allow read, delete: if request.auth != null;
    }
    
    // ─── Tokens de autenticación de clientes ──────────────────────────────────────────
    match /tokens/{tokenId} {
      // Solo el desarrollador autenticado puede gestionar y leer tokens
      allow read, write: if request.auth != null;
    }

    // ─── Configuración de tasas comisionales por cliente SaaS ─────────────────────────
    match /clientes_saas/{clientId} {
      // La app cliente puede leer su propia configuración si tiene un token válido
      // El token se pasa como query param: ?token=xxx  — lo leemos del header custom no disponible en Firestore.
      // Alternativa: permitir lectura pública del propio documento validando el clientId con el token.
      // Como Firestore no permite recibir headers, usamos una regla más simple:
      // La app puede leer su propio doc si presenta el token correcto en el campo de la solicitud.
      // Dado que esto es una lectura (no escritura), no tenemos request.resource. 
      // Solución: permitir lectura pública del documento del cliente (solo datos de comisión, no sensibles).
      allow read: if true; // El doc solo contiene: comisionPorcentaje, nombre. No hay datos sensibles.
      allow write: if request.auth != null; // Solo el developer desde la consola puede modificar
    }
  }
}

